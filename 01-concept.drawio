        <mxCell id="eIposEHRdqCibFXUl9mP-30" value="&lt;font style=&quot;font-size: 17px;&quot;&gt;Background Design&lt;/font&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(107, 255, 242));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Parallax :&lt;/font&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(178, 102, 255));&quot;&gt; &lt;/font&gt;different layers behaves&amp;nbsp; &amp;nbsp; different behavior on scrolling.&amp;nbsp;&lt;a href=&quot;https://www.youtube.com/watch?v=UgIwjLg4ONk&quot;&gt;Tutorial&lt;/a&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Tool [Lenix]&amp;nbsp;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;spacingLeft=-20;" vertex="1" parent="1">
